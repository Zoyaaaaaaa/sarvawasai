# Environment Configuration Template for Legal Analysis API
# Copy this file to backend/app/.env and fill in your values

# ==========================================
# Google Generative AI Configuration
# ==========================================
# Required for the Legal Document Analysis API
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Specify API version (default: v1)
# GOOGLE_API_VERSION=v1

# Optional: Set request timeout in seconds (default: 120)
# API_REQUEST_TIMEOUT=120

# ==========================================
# MongoDB Configuration (if using)
# ==========================================
# MongoDB connection string for storing analysis results
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/

# ==========================================
# Application Configuration
# ==========================================
# Environment: development or production
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=true

# ==========================================
# Logging Configuration
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# API Configuration
# ==========================================
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# API rate limiting
# MAX_REQUESTS_PER_MINUTE=60
# MAX_BATCH_SIZE=10

# ==========================================
# Optional: Custom Prompts and Settings
# ==========================================
# Set to true to enable custom legal analysis prompts
# USE_CUSTOM_PROMPTS=false

# Default language for responses
# DEFAULT_LANGUAGE=english

# ==========================================
# Storage Configuration (if storing results)
# ==========================================
# Local storage directory for analysis results
# STORAGE_PATH=./analysis_results

# ==========================================
# External Services
# ==========================================
# Optional: DocuSeal or other document signing service
# DOCUSEAL_API_KEY=your-key-here

# Optional: IPFS for document storage
# IPFS_NODE_URL=https://ipfs.io

# ==========================================
# Notes
# ==========================================
# - GOOGLE_API_KEY is REQUIRED for the Legal Analysis API to work
# - Keep this file in backend/app/ but do NOT commit to version control
# - Update .gitignore to exclude .env files
# - For production, use a secrets management service instead of .env
# - Restart the backend after changing environment variables
